# OpenAI API Configuration
OPENAI_API_KEY=your_api_key_here

# LLM Configuration
# Provider: openrouter, openai, anthropic, none (default: none)
LLM_PROVIDER=none

# LLM API key (optional - falls back to OPENAI_API_KEY or ANTHROPIC_API_KEY)
# LLM_API_KEY=your_llm_api_key_here

# LLM base URL (optional - auto-configured for openrouter)
# OpenRouter: https://openrouter.ai/api/v1
# LLM_BASE_URL=https://openrouter.ai/api/v1

# LLM temperature (default: 0.7)
# LLM_TEMPERATURE=0.7

# Component-specific LLM models (optional - falls back to provider default)
# News collector: model for article classification
# NEWS_COLLECTOR_LLM_MODEL=qwen/qwen3.5-27b

# Report generator: model for report generation
# REPORT_GENERATOR_LLM_MODEL=qwen/qwen3.5-27b

# Entity extractor: model for entity extraction
# ENTITY_EXTRACTOR_LLM_MODEL=qwen/qwen3.5-27b

# Technology analyzer: model for technology analysis
# TECHNOLOGY_ANALYZER_LLM_MODEL=qwen/qwen3.5-27b

# RSS Feed Configuration
# Path to JSON file containing RSS sources (optional - defaults to built-in sources)
# See config/rss_sources.json for the default configuration
RSS_SOURCES_FILE=config/rss_sources.json

# Alternative: Comma-separated list of RSS feed URLs (overrides RSS_SOURCES_FILE if set)
# RSS_SOURCES=https://techcrunch.com/feed/,https://www.theverge.com/rss/index.xml

# Technology keywords for article filtering (optional - defaults to built-in keyword list)
# Can also be a path to a JSON file containing keywords
# RSS_KEYWORDS=AI,machine learning,blockchain,quantum computing
# RSS_KEYWORDS_FILE=config/keywords.json

# Content extraction settings
RSS_CONTENT_TIMEOUT=30

# Failure logging settings
RSS_LOG_FAILURES=true
RSS_LOG_FILE=./logs/rss_failures.log
